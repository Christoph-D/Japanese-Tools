{
    "name": "Japanese Learning Tools",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "esbenp.prettier-vscode",
                "mkhl.shfmt",
                "ms-python.python",
                "rust-lang.rust-analyzer",
            ],
            "settings": {
                "prettier.proseWrap": "always",
                "files.insertFinalNewline": true
            }
        }
    },
    "workspaceFolder": "/workspaces/Japanese",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/Japanese,type=bind,consistency=cached",
    "remoteUser": "ubuntu",
    "mounts": [
        "source=config-japanese-tools,target=/home/ubuntu/persistent-config,type=volume",
        "source=/etc/localtime,target=/usr/share/zoneinfo/hostlocaltime,type=bind,readonly"
    ]
}
